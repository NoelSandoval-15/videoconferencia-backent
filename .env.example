# ===== EMAIL CONFIGURATION (GMAIL) =====
# Instrucciones:
# 1. Ir a https://myaccount.google.com/security
# 2. Activar "Verificación en dos pasos"
# 3. En "Contraseñas de aplicaciones", seleccionar "Mail" y "Windows"
# 4. Copiar contraseña generada y pegarla en EMAIL_HOST_PASSWORD
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
